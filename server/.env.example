# --- Server ---
PORT=7100
NODE_ENV=development

# --- Database ---
# Local dev: mongodb://127.0.0.1:27017/hiwaga
# Production (Atlas): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/hiwaga?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/hiwaga

# --- CORS ---
# Comma-separated list of allowed front-end origins
CORS_ORIGIN=http://localhost:7040

# --- Admin auth (temp env-based until a Users collection is added) ---
ADMIN_EMAIL=admin@hiwagamakers.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Hiwaga Admin

# --- JWT ---
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRY=7d

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880   # 5 MB in bytes
